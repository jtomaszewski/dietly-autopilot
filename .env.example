# Copy to .env and fill in. .env is gitignored — never commit credentials.
DIETLY_EMAIL=you@example.com
DIETLY_PASSWORD=your-dietly-password

# Catering slug (Dietly "company-id" header). Default: wybormenu (Wybór Menu).
DIETLY_COMPANY_ID=wybormenu

# How many days ahead to consider (only days still inside the edit window are touched).
DIETLY_HORIZON_DAYS=14

# OpenRouter — the model makes the meal decisions. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=google/gemini-2.5-flash

# Optional: path to your guidelines markdown (default GUIDELINES.md)
# DIETLY_GUIDELINES_PATH=GUIDELINES.md
